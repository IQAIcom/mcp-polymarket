# Example .env file for trading configuration
# Copy this to .env and fill in your values

# Your private key (NEVER commit this file with real values!)
POLYMARKET_PRIVATE_KEY=your_private_key_here

# Polygon RPC URL (defaults to https://polygon-rpc.com)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_key

# Polymarket CLOB API base URL (defaults to https://clob.polymarket.com)
CLOB_API_BASE=https://clob.polymarket.com

# Polygon Chain ID (137 for mainnet)
CHAIN_ID=137

# Your proxy/funder wallet address (required for proxy wallets, optional for EOAs)
POLYMARKET_FUNDER=your_proxy_wallet_address_here

# Signature type (0 = EOA, 1 = Proxy wallet, 2 = Gnosis Safe). Auto-detected if omitted.
SIGNATURE_TYPE=2
